# skyMem environment template. Copy to .env and fill in your keys.

# Database
DATABASE_URL="mysql://root:skypassword@localhost:3306/skymem?connection_limit=20"
MYSQL_ROOT_PASSWORD="skypassword"

# LLM keys (BYOK)
ANTHROPIC_API_KEY="sk-ant-..."
COHERE_API_KEY="..."

# Embedding provider — Cohere v3 (1024d, retrieval-tuned)
SKY_EMBED_PROVIDER=cohere

# Reranker
SKY_RERANK_PROVIDER=cohere

# Mode (pa | builder | demo)
SKY_MODE=demo

# Persona block size in chat (default 10)
SKY_PERSONA_CHAT_LIMIT=10

# Disable temporal axes extraction if API budget is tight
# SKY_TEMPORAL_AXES=off

# Optional: Ollama for local cheap LLM
# OLLAMA_URL=http://host.docker.internal:11434
